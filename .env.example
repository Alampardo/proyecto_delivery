# Copia este archivo como .env en la raíz del proyecto, en el VPS.
# Estos valores deben coincidir con los que pusiste en backend/.env
# (docker-compose los usa para sustituir variables dentro de docker-compose.yml).

DB_NAME=delivery_db
DB_USER=postgres
DB_PASSWORD=reemplaza-esto-con-una-password-nueva

# Mismo valor que ADMIN_WHATSAPP en backend/.env
VITE_ADMIN_WHATSAPP=591XXXXXXXXX

# Mismo valor que VAPID_PUBLIC_KEY en backend/.env
VITE_VAPID_PUBLIC_KEY=
