# Copia este archivo como backend/.env en el VPS y completa los valores reales.
# Genera un SECRET_KEY nuevo y una DB_PASSWORD nueva — nunca reutilices los de desarrollo local.
# Generar SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

SECRET_KEY=reemplaza-esto-con-una-clave-nueva-y-larga

DEBUG=False

# PostgreSQL (dentro de docker-compose el host es el nombre del servicio: "db")
DB_NAME=delivery_db
DB_USER=postgres
DB_PASSWORD=reemplaza-esto-con-una-password-nueva
DB_HOST=db
DB_PORT=5432

# IP o dominio real del VPS, separados por coma si hay varios
ALLOWED_HOSTS=TU_IP_DEL_VPS

# WhatsApp del administrador
ADMIN_WHATSAPP=591XXXXXXXXX

# Debe apuntar al mismo origen (http:// + IP/dominio del VPS)
# Si el contenedor "web" no publica el puerto 80 (por ejemplo, porque ya hay
# otro servicio usándolo), incluye el puerto: http://TU_IP_DEL_VPS:8081
CORS_ALLOWED_ORIGINS=http://TU_IP_DEL_VPS
FRONTEND_URL=http://TU_IP_DEL_VPS

# Email (igual que en desarrollo, o tus credenciales reales de producción)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Claves VAPID (pueden ser las mismas que en desarrollo)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@tudominio.com
