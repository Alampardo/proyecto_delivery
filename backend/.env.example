# Copia este archivo como .env y completa los valores reales
SECRET_KEY=tu-clave-secreta-django-aqui-cambiar-en-produccion

DEBUG=True

# PostgreSQL
DB_NAME=delivery_db
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_HOST=localhost
DB_PORT=5432

# WhatsApp del administrador (número sin espacios ni guiones, con código de país)
ADMIN_WHATSAPP=591XXXXXXXXX

# CORS — URL del frontend en desarrollo
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Claves VAPID para Web Push Notifications
# Generarlas con: python manage.py generate_vapid_keys
VAPID_PRIVATE_KEY=tu_clave_privada_vapid_aqui
VAPID_PUBLIC_KEY=tu_clave_publica_vapid_aqui
VAPID_CLAIMS_EMAIL=admin@tudominio.com
